ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://language_user:language_pass@pgbouncer:6432/language_ai
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost","http://localhost:3000"]
AUTO_CREATE_SCHEMA=true
DEFAULT_LLM_PROVIDER=mock
DEFAULT_STT_PROVIDER=mock
DEFAULT_TTS_PROVIDER=mock
DEFAULT_EMBEDDING_PROVIDER=mock
DEFAULT_RERANK_PROVIDER=none
EMBEDDING_DIMENSION=64
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_LLM_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_STT_MODEL=whisper-large-v3-turbo
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_LLM_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_NIM_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3
COHERE_API_KEY=
COHERE_API_BASE_URL=https://api.cohere.com
COHERE_EMBEDDING_MODEL=embed-v4.0
COHERE_RERANK_MODEL=rerank-v3.5
DEEPGRAM_API_KEY=
DEEPGRAM_API_BASE_URL=https://api.deepgram.com
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
ADMIN_RAG_ALLOW_OPERATIONAL_PII=false
ADMIN_MASTER_PASSWORD=admin123
ADMIN_SESSION_SECRET=change-me-use-a-long-random-secret
ADMIN_SESSION_COOKIE=linguaflow_admin
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_COOKIE_SECURE=false
USER_SESSION_SECRET=change-me-use-another-long-random-secret
USER_SESSION_COOKIE=linguaflow_user
USER_SESSION_TTL_SECONDS=1209600
PASSWORD_RESET_TTL_SECONDS=1800
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback
FRONTEND_POST_LOGIN_URL=http://localhost/chat
FRONTEND_ONBOARDING_URL=http://localhost/onboarding
